#: data/ca.andyholmes.Valent.desktop.in.in:3
#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:12
msgid "Connect, control and sync devices"
msgstr "Подключение, управление и синхронизация устройств"

#: data/ca.andyholmes.Valent.gschema.xml:10
#: src/plugins/gnome/valent-preferences-command-editor.ui:41
msgid "Name"
msgstr "Имя"

#: data/ca.andyholmes.Valent.gschema.xml:11
msgid "The display name for the local device."
msgstr "Отображаемое имя локального устройства."

#: data/ca.andyholmes.Valent.gschema.xml:15
#: src/plugins/gnome/valent-preferences-dialog.ui:93
msgid "Device Addresses"
msgstr "Адреса устройств"

#: data/ca.andyholmes.Valent.gschema.xml:16
#: src/plugins/gnome/valent-preferences-dialog.ui:63
msgid "Add devices by hostname or IP address"
msgstr "Добавьте устройства по имени хоста или IP-адресу"

#: data/ca.andyholmes.Valent.gschema.xml:22
msgid "Plugin State"
msgstr "Состояние плагина"

#: data/ca.andyholmes.Valent.gschema.xml:23
msgid "Whether the plugin is enabled or not."
msgstr "Включён плагин или нет."

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:15
msgid ""
"Securely connect your devices to open files and links where you need them, "
"get notifications when you need them, stay in control of your media and more."
msgstr ""
"Безопасно подключайте устройства, чтобы открывать файлы и ссылки там, где "
"нужно, получать уведомления вовремя, управлять медиа и многое другое."

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:19
msgid "Features:"
msgstr "Возможности:"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:23
msgid "Sync contacts, notifications and clipboard content"
msgstr "Синхронизация контактов, уведомлений и содержимого буфера обмена"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:24
msgid "Control media players and volume"
msgstr "Управление медиаплеерами и громкостью"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:25
msgid "Share files, links and text"
msgstr "Обмен файлами, ссылками и текстом"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:26
msgid "Virtual touchpad and keyboard"
msgstr "Виртуальный тачпад и клавиатура"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:27
msgid "Call and text notification"
msgstr "Уведомления о звонках и SMS"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:28
msgid "Execute custom commands"
msgstr "Выполнение пользовательских команд"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:29
msgid "More…"
msgstr "Ещё…"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:31
msgid ""
"Valent is an implementation of the KDE Connect protocol, built on GNOME "
"platform libraries."
msgstr ""
"Valent — реализация протокола KDE Connect, построенная на библиотеках "
"платформы GNOME."

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:42
msgid "Support connecting to devices by IP address"
msgstr "Поддержка подключения к устройствам по IP-адресу"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:43
msgid "Support compose mode and grab release for input remote"
msgstr "Поддержка режима compose и grab release для удалённого ввода"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:44
msgid "Support mounting specific SFTP volumes"
msgstr "Поддержка монтирования конкретных SFTP-томов"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:45
msgid ""
"Improve async operations for device connections, file transfers and mDNS"
msgstr "Улучшение асинхронных операций для подключений, передачи файлов и mDNS"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:46
msgid "Improve cross-platform support for launching URIs"
msgstr "Улучшение кроссплатформенной поддержки запуска URI"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:47
msgid "Various protocol updates"
msgstr "Различные обновления протокола"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:48
msgid "Fixes for certificates and devices IDs"
msgstr "Исправления для сертификатов и ID устройств"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:49
msgid "Fixes for modemmanager and signal strengths"
msgstr "Исправления для modemmanager и уровня сигнала"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:50
#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:61
#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:76
msgid "Translation updates"
msgstr "Обновления переводов"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:58
msgid "Support v8 of the KDE Connect protocol"
msgstr "Поддержка версии 8 протокола KDE Connect"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:59
msgid "The Contacts plugin has been rewritten with TinySPARQL"
msgstr "Плагин контактов переписан с использованием TinySPARQL"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:60
msgid "Drop the Mutter input adapter in favour of the XDG portal"
msgstr "Удалён адаптер ввода Mutter в пользу XDG portal"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:69
msgid "PipeWire support added"
msgstr "Добавлена поддержка PipeWire"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:70
msgid "The user interface has been absorbed by the `gnome` plugin"
msgstr "Пользовательский интерфейс интегрирован в плагин `gnome`"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:71
msgid "The SMS plugin has been rewritten with TinySPARQL"
msgstr "Плагин SMS переписан с использованием TinySPARQL"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:72
msgid "The share dialog has been redesigned"
msgstr "Диалог обмена переработан"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:73
msgid "The media dialog has been refactored, with some UI improvements"
msgstr "Диалог медиа рефакторирован с улучшениями интерфейса"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:74
msgid "Port to libawaita-1.5"
msgstr "Порт на libawaita-1.5"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:75
msgid ""
"Updates to protocol implementation; certificates, device metadata, security"
msgstr ""
"Обновления реализации протокола: сертификаты, метаданные устройств, "
"безопасность"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:83
msgid "Initial release."
msgstr "Первая версия."

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:90
msgid "Connect to devices on your network"
msgstr "Подключение к устройствам в сети"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:94
msgid "Securely pair devices"
msgstr "Безопасная привязка устройств"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:98
msgid "Monitor and control remote devices"
msgstr "Мониторинг и управление удалёнными устройствами"

#: data/metainfo/ca.andyholmes.Valent.metainfo.xml.in.in:116
msgid "Andy Holmes"
msgstr "Andy Holmes"

